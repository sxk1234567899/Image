}
#WgtRegNo1Class #pushButtonMode
{
  background-color: #FFFFFF;
  color: #1563FF;
  border: 3px solid #1563FF;
  border-radius: 35px;
  font: 700 30px "Microsoft YaHei UI";
}
#WgtRegNo1Class #labelBatchPage,#WgtRegNo1Class #labelListPage,#WgtVerifyNo1Class #labelBatchPage,#WgtVerifyNo1Class #labelListPage
{
  font: 22px "Microsoft YaHei UI";
}
#WgtRegNo1Class QTabWidget,#WgtVerifyNo1Class QTabWidget
{
  background:#FFFFFF;
  border: none;
  border-radius: 0;
  gridline-color: transparent;  /* 确保网格线不可见 */
}
#WgtRegNo1Class #tableWidgetBatch::item,#WgtVerifyNo1Class #tableWidgetBatch::item
{
  background:transparent ;
   border: none;
  border-bottom: 20px solid #FFFFFF;
}
#WgtRegNo1Class #tableWidgetList::item,#WgtVerifyNo1Class #tableWidgetList::item 
{
  background:#F1F1F1 ;
  border: none;
  border-bottom: 20px solid #FFFFFF;
}

#WgtRegNo1Class #stackedWidget QToolButton,#WgtVerifyNo1Class #stackedWidget QToolButton
{
  background-color:#000000 ;
  border: 1px;
  border-radius: 26px;
}
#WgtRegNo2Class #widgetImage
{
  background-color:#FFFFFF;
  color: #000000;
}
#WgtRegNo2Class QRadioButton 
{
  color: #000000;
  font: 700 30px "Microsoft YaHei UI";
  background-color: #FFFFFF;
  /*border-radius: 4px;*/
  spacing: 20px;
  padding-right: 2px; 
  padding-left: 2px;  
  border-top: 1px solid #000000;
  border-bottom: 1px solid #000000;
  border-right: 1px solid #DDDDDD;
}
#WgtRegNo2Class QRadioButton:checked 
{
	background-color: #1563ff;
	color: #FFFFFF;

}
#WgtRegNo2Class QRadioButton::indicator 
{
	width: 16px;
	height: 16px;
	subcontrol-position: top left;
	right: 2px;
	top: 2px;
	
}
#WgtRegNo2Class QRadioButton::indicator:unchecked 
{
	image: url(:/image/unchecked.png);
}

#WgtRegNo2Class QRadioButton::indicator:checked 
{
	image: url(:/image/checked.png);
} 

#WgtRegNo2Class #radioButtonTop
{
  border-top: 1px solid #000000;
  border-bottom: 1px solid #000000;
  border-left: 1px solid #000000;
  border-right: 1px solid #DDDDDD;
  /* 左侧圆角效果 */
  border-top-left-radius: 30px;    /* 左上角圆角半径 */
  border-bottom-left-radius: 30px; /* 左下角圆角半径 */
}

#WgtRegNo2Class #radioButtonPar
{
  spacing: 0px;
  padding-right: 20px; 
  padding-left: 5px;  
  border-top: 1px solid #000000;
  border-bottom: 1px solid #000000;
  border-right: 1px solid #000000;
  /* 右侧圆角效果 */
  border-top-right-radius: 30px;    /* 左上角圆角半径 */
  border-bottom-right-radius: 30px; /* 左下角圆角半径 */
}
#WgtRegNo21Class,#WgtRegNo3Class #spinBoxGMarked,#WgtRegNo3Class #spinBoxAllMarked
{
  background-color: transparent;
}
#WgtRegNo3Class #labelImage
{
  background-color:#000000;
}
#WgtRegNo3Class #labelInfoIcon,#WgtRegNo4Class #labelInfoIcon,#WgtVerifyNo3Class #labelInfoIcon,#WgtVerifyNo4Class #labelInfoIcon
