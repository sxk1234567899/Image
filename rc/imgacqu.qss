}
#WgtRegNo4Class QRadioButton,#WgtVerifyNo4Class QRadioButton 
{
  color: #000000;
  font: 700 30px "Microsoft YaHei UI";
  background-color: #FFFFFF;
  /*border-radius: 4px;*/
  spacing: 20px;
  padding-right: 10px; 
  padding-left: 10px;  
  border: 2px solid #000000;
}
#WgtRegNo4Class QRadioButton::disabled,#WgtVerifyNo4Class QRadioButton::disabled
{
    background-color: #cccccc; /* 灰色背景 */
    color: #888888;            /* 浅灰色文本 */
