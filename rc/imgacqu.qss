  border-bottom-left-radius: 35px; /* 左下角圆角半径 */
  icon: url(:/image/low.png);
  icon-size: 50;
}
#WgtRegNo4Class #radioButtonHgt,#WgtVerifyNo4Class #radioButtonHgt
{
  /* 左侧圆角效果 */
  border-top-right-radius: 35px;    /* 左上角圆角半径 */
  border-bottom-right-radius: 35px; /* 左下角圆角半径 */
}
#WgtRegNo4Class QRadioButton::indicator,#WgtVerifyNo4Class QRadioButton::indicator  
{
	width: 16px;
	height: 16px;
	
  border-radius: 8px;
}
#WgtRegNo4Class QRadioButton:checked,#WgtVerifyNo4Class QRadioButton:checked 
{
	background-color: #000000;
	color: #FFFFFF;

}
#WgtRegNo4Class QRadioButton::indicator:unchecked,#WgtVerifyNo4Class QRadioButton::indicator:unchecked 
{
	background-color: #FFFFFF;
	color:  #FFFFFF;
}

#WgtRegNo4Class QRadioButton::indicator:checked,#WgtVerifyNo4Class QRadioButton::indicator:checked 
{
  background-color: #00FF17;
	color:  #00FF17;
} 

#WgtRegNo4Class #pushButtonPhoto,#WgtVerifyNo4Class #pushButtonPhoto
{
  padding-left: 0px;          /* 为图标留出空间 */
  spacing: 30px;  
  text-align: left;            /* 文本左对齐 */
  background-color: #000000;
}

