/*全局通用样式*/
* {
  padding: 0px;        /* 移除内边距 */
  margin: 0px;         /* 移除外边距 */
  border: 0px;         /* 移除边框宽度 */
  border-style: none;  /* 移除边框样式 */
  border-image: none;  /* 移除边框图片 */
  outline: 0;          /* 移除焦点轮廓 */
  background-color: #FFFFFF; /* 设置白色背景 */
  color: #000000;
  font: 25px "Microsoft YaHei UI";
}

QLabel
{
  background-color:#FFFFFF;
  color: #000000;
  border-style:outset;
  border: 0px;
  font: 40px "Microsoft YaHei UI";
}

QPushButton
{
  background-color: #1563FF;
  color: #FFFFFF;
  border: 3px solid #FFFFFF;
  border-radius: 35px;
  font: 700 30px "Microsoft YaHei UI";
}
QPushButton:disabled
{
    background-color: #cccccc; /* 灰色背景 */
    color: #888888;            /* 浅灰色文本 */
    border: 1px solid #aaaaaa; /* 边框 */
}
QLineEdit
{
  border-radius: 4px;
  border: 3px solid #666666;
  font: 26px "Microsoft YaHei UI";
}

QProgressBar
{
  border-style:outset;
  border-radius: 0px;
  font: 700 20px "Microsoft YaHei UI";
}
QProgressBar::chunk {
  background-color:#1563FF;
  border-style:outset;
  border-radius: 0px;
}
QTimeEdit,QDateEdit,QDateTimeEdit
{
  background-color: transparent;
  border-width:0;
  border-style:outset;
  font: 12pt "Microsoft YaHei UI";
}

QScrollArea
{
  background-color:#FFFFFF;
  color: #000000;
}
QVideoWidget,#videoWidget
{
  background:#000000
}

QSpinBox
{
  background:#E6E6E6;
  color: #000000;
  font: 28px "Microsoft YaHei UI";
  border: 0;
}
QTabWidget 
{
  background:#FFFFFF;
  border: none;
  border-radius: 0;
  gridline-color: transparent;  /* 确保网格线不可见 */
}
QTableView::item 
{
  background:#FFFFFF;
  border: none;
  border-bottom: 4px solid #E6E6E6;
  padding: 4px;
}
QTableView::item:selected 
{
  background:#FFFFFF;
  border: none;
  border-bottom: 4px solid #E6E6E6;
  padding: 4px;
  color: #1563FF;
  font: 700 25px "Microsoft YaHei UI";
}
QHeaderView 
{
  background:#FFFFFF;
  color: #000000;
  border: 0px;
  border-radius: 0;

}
QHeaderView::section 
{
  background:#FFFFFF;
  color: #000000;
  border: none;           /* 隐藏表头分割线 */
  border-bottom: 4px solid #E6E6E6;  /* 保留底部边框作为行分割线 */
  padding: 4px;
}
QDialog
{
  background-color:#FFFFFF;
  color: #000000;
  border-style:outset;
  border: 2px solid #E6E6E6; 
  font: 20px "Microsoft YaHei UI";
}
QDialogButtonBox QPushButton 
{
	max-width:100px;
	max-height:70px;
	min-width: 100px;
	min-height: 70px;
}

QSlider::groove:horizontal{
background:#243D5B;
height:60px;
border-radius:4px;
}

QSlider::add-page:horizontal{
background:#FFFFFF;
}

QSlider::sub-page:horizontal{
background:#1563FF;
}

QSlider::handle:horizontal{
width:40px;
margin-top:-3px;
margin-bottom:-3px;
border-radius:6px;
background:qradialgradient(spread:pad,cx:0.5,cy:0.5,radius:0.5,fx:0.5,fy:0.5,stop:0.6 #1B3149,stop:0.8 #0F1F2F);
}

QTextBrowser
{
  color: #555555;
  font: 22px "Microsoft YaHei UI";

}

/*针对WgtHomeClass的状态*/
#WgtHomeClass #widgetSave,#WgtHomeClass #widgetNet,#WgtHomeClass #widgetDevice,#WgtHomeClass #widgetSys
{
  background-color:#F1F1F1;
  color: rgb(0, 0, 0);
  border-style:outset;
  border: 1px solid #DDDDDD;
  border-radius: 10px;
  font: 40px "Microsoft YaHei UI";
}
#WgtHomeClass QLabel
{
  background-color:#F1F1F1;
  color: #000000;
  border-style:outset;
  border: 0px;
  font: 40px "Microsoft YaHei UI";
}
#WgtHomeClass #labelWifi,#WgtHomeClass #label4g,#WgtHomeClass #labelPrinter,#WgtHomeClass #labelUSBCamera,#WgtHomeClass #labelNetCamera
{
  font: 20px "Microsoft YaHei UI";
}
#widgetSys  QLabel
{
  font: 30px "Microsoft YaHei UI";
}
#WgtHomeClass QPushButton
{
background-color: #FFFFFF;
color: #1563FF;
border-radius: 16px;
border: 3px solid #111111;
font: 700 78px "Microsoft YaHei UI";
}

/*针WgtLogoClass对*/
#WgtLogoClass ,#WgtLogoClass QLabel
{
  background-color:#FFFFFF;
  font: 24px "Microsoft YaHei UI";
  color: rgb(0, 0, 0);
}
#WgtLogoClass #labelTitle
{
  background-color:#FFFFFF;
  font:  30px "Microsoft YaHei UI";
  color: rgb(0, 0, 0);
}
#WgtLogoClass ,#WgtLogoClass QLineEdit
{
  border-radius: 40px;
  font: 30px "Microsoft YaHei UI";
}

#WgtLogoClass QPushButton
{
    border-radius: 40px;
    font: 30px "Microsoft YaHei UI";
}
#WgtLogoClass #pushButtonSet
{
    border-radius: 0px;
    background-color: transparent;
}

/*WgtMainClass*/
#widgetTop
{
    background-color: qlineargradient( spread: pad, x1:0, y1:0, x2:1, y2:0, stop:0 #0049DA, stop:1 #5D93FF);
}
#widgetTop #labelName
{
  font: 700 22px "Microsoft YaHei UI";
  color:#FFFFFF;
  background-color: transparent;
}
#widgetTop #labelBatt
{
  font: 14px "Microsoft YaHei UI";
  color:#000000;
  background-color: transparent;
  background-image: url(":/image/batt.png");
}
#labelLogInfo
{
  color:#FFFFFF;
  background-color: transparent;
  font: 18px "Microsoft YaHei UI";
}
#widgetTop #widgetTopHome,#widgetTop #widgetTopQuit
{
  background-color: transparent;
}
#widgetTop #pushButtonHome,#widgetTop #pushButtonBack,#widgetTop #pushButtonLogOut
{
  color:#FFFFFF;
  font: 20px "Microsoft YaHei UI";
  background-color: transparent;
  border-width:0;
  border-style:outset;
}
#widgetTop #timeEdit,#widgetTop #dateEdit
{
  color:#FFFFFF;
  background-color: transparent;
  border-width:0;
  border-style:outset;
  font: 12pt "Microsoft YaHei UI";
}



/*设置WgtRegClass及相关页样式*/
#stackedWidget,#WgtRegClass,#WgtRegNo1Class,QWidget #WgtRegNo2Class,#WgtRegNo3Class,#WgtRegNo4Class,#WgtRegNo5Class,#widgetTool
{
  background-color:#E6E6E6;
}
#WgtRegNo1Class QLabel
{
  font: 28px "Microsoft YaHei UI";
}
#WgtRegNo1Class #labelCode2d
{
